PORT=4000
NODE_ENV=development

// change the URL to port number 5433 if facing issue "ERRCONN"
DATABASE_URL=postgres://postgres:postgres@localhost:5432/web_researcher

// Provider routing: openrouter|grok and legacy|tavily
LLM_PROVIDER=openrouter
SEARCH_PROVIDER=legacy

// OpenRouter provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

// Grok provider
GROK_API_KEY=
GROK_MODEL=grok-3-mini
GROK_API_BASE_URL=https://api.x.ai/v1/chat/completions

// Tavily provider
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
TAVILY_SEARCH_URL=https://api.tavily.com/search
TAVILY_EXTRACT_URL=https://api.tavily.com/extract
TAVILY_MAX_RESULTS=8
TAVILY_SEARCH_TIMEOUT_MS=14000
TAVILY_EXTRACT_TIMEOUT_MS=12000
TAVILY_INCLUDE_ANSWER=false
