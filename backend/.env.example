PORT=4000
NODE_ENV=development

# change the URL to port number 5433 if facing issue "ECONNREFUSED"
DATABASE_URL=postgres://postgres:postgres@localhost:5432/web_researcher

# Grok API (xAI) - used for LLM content generation (replaces OpenRouter)
# Get your API key at https://console.x.ai/
XAI_API_KEY=

# Optional: override the default Grok model (default: grok-3-mini)
GROK_MODEL=grok-3-mini

# Tavily API - used for web search and source discovery
# Get your API key at https://app.tavily.com/
TAVILY_API_KEY=
